{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node", "electron", "vitest/globals"],
    "rootDir": ".",
    "outDir": "dist-electron",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false
  },
  "include": [
    "electron/**/*.ts",
    "electron/**/*.mts",
    "src/core/**/*.ts",
    "src/main/**/*.ts",
    "src/providers/**/*.ts",
    "src/plugins/**/*.ts",
    "src/profiles/**/*.ts",
    "src/storage/**/*.ts",
    "src/renderer/workflow.ts",
    "src/shared/**/*.ts",
    "tests/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
