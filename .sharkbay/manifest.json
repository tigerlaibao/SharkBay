  },
  "runtime": {
    "localUrl": "unknown",
    "deploymentUrl": "unknown",
    "testUrl": "unknown"
  },
  "files": {
    "state": ".agent/state.json",
    "queue": ".agent/queue.json",
    "protocol": ".agent/protocol.md",
    "humanState": ".agent/state.md",
    "humanQueue": ".agent/queue.md",
    "development": ".agent/development.json"
  }
}
